rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Backgrounds — publicly readable, only admin can write (via server/Admin SDK)
    match /backgrounds/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Stories — anyone can read (players load via invite code), only auth can write
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reflections — top-level collection, anyone can read/write (players are unauthenticated)
    match /reflections/{reflectionId} {
      allow read, write: if true;
    }

    // Reflections as subcollection (fallback)
    match /stories/{storyId}/reflections/{reflectionId} {
      allow read, write: if true;
    }

    // Music library — read only
    match /music/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Users — each user reads/writes only their own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Applications — authenticated users can create/read their own applications
    match /applications/{applicationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
