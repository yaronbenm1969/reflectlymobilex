# ─────────────────────────────────────────────
# Reflectly Mobile — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── Firebase (client SDK) ─────────────────────
# Get these from Firebase Console → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Local server ──────────────────────────────
# Use your machine's LAN IP so the iPhone can reach it over Wi-Fi.
# Find it with: ipconfig (Windows) → Wi-Fi → IPv4 Address
# Example: http://192.168.1.42:5000
# DO NOT use localhost — the phone can't reach your machine's localhost.
EXPO_PUBLIC_API_URL=http://192.168.1.XX:5000
EXPO_PUBLIC_VIDEO_CONVERTER_URL=http://192.168.1.XX:5000

# ── Web player share domain ───────────────────
# Domain embedded in WhatsApp share links.
# For local testing: your LAN IP + port (e.g. 192.168.1.42:5000)
# For production: leave blank to use the Replit fallback in app.config.js
EXPO_PUBLIC_WEB_PLAYER_DOMAIN=

# ── Access gate (optional) ────────────────────
# If blank, the access gate is bypassed automatically.
EXPO_PUBLIC_ACCESS_CODE=

# ── Firebase Admin (server only, never in EXPO_PUBLIC_) ──
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_PROJECT_ID=

# ── Other server-side keys ────────────────────
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
