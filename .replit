modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "web-player"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "video-converter"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "expo-app"

[[workflows.workflow]]
name = "web-player"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node web-player/server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "video-converter"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server/video-converter-api.js"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "expo-app"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --tunnel"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["ffmpeg"]

[userenv]

[userenv.shared]
WEB_PLAYER_URL = "https://your-reflectly-web.replit.app"

[deployment]
deploymentTarget = "static"
run = ["node", "web-player/server.js"]
publicDir = "web-player"
